# =========================================================================
# Payments & Webhook Integration Layer — environment template
#
# Copy to .env and fill in your own values:   cp .env.example .env
# NEVER commit .env. All values below are placeholders — no real secrets.
# =========================================================================

# --- Docker host port ----------------------------------------------------
# A random free high port. scripts/run_free_port.ps1 picks and writes one for
# you. The container always listens on 8000; compose maps ${APP_PORT}:8000.
APP_PORT=

# --- Core Django ---------------------------------------------------------
# Generate one:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
# Required in production. If left empty an insecure development key is used.
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Comma-separated origins, e.g. http://localhost:12345 (match your APP_PORT)
CSRF_TRUSTED_ORIGINS=
SITE_NAME=PayBridge
TIME_ZONE=UTC

# --- Dashboard admin -----------------------------------------------------
# The admin account is created ONLY when ADMIN_PASSWORD is set. Choose your
# own strong password — there is no built-in default.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- Payment processor credentials (ALL OPTIONAL) ------------------------
# Leave empty to run in DEMO_MODE: signatures are accepted in demo mode and
# payments are simulated, so the project is fully usable with no processor
# account. Supplying a secret switches that processor to strict verification.
DEMO_MODE=True
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Retry / backoff -----------------------------------------------------
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_SECONDS=30
RETRY_MAX_BACKOFF_SECONDS=3600

# --- Logging -------------------------------------------------------------
LOG_LEVEL=INFO
